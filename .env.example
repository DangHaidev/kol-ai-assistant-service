APP_NAME=KOL AI Assistant Service
APP_ENV=development
APP_PORT=8001

DATABASE_URL=postgresql+asyncpg://kol_user:kol_secret@localhost:5432/kol_booking

SPRING_BACKEND_BASE_URL=http://localhost:8080
SPRING_BACKEND_INTERNAL_TOKEN=change_me
BACKEND_MOCK_CANDIDATES_PATH=mock_data/backend_search_candidates.json

LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://ckey.vn/v1
OPENAI_MODEL=gpt-5.4-mini

REQUEST_TIMEOUT_SECONDS=10
MAX_RECOMMENDATION_CANDIDATES=50
DEFAULT_TOP_K=5
